<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.RadminVPN" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#2979FF</item>
        <item name="colorPrimaryVariant">#1565C0</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#00E676</item>
        <item name="colorSecondaryVariant">#00C853</item>
        <item name="colorOnSecondary">#000000</item>
        <item name="colorSurface">#1E1E2E</item>
        <item name="colorOnSurface">#E0E0E0</item>
        <item name="android:colorBackground">#121218</item>
        <item name="android:windowBackground">#121218</item>
        <item name="android:statusBarColor">#0D0D14</item>
        <item name="android:navigationBarColor">#0D0D14</item>
    </style>

    <style name="Theme.RadminVPN.Settings" parent="Theme.RadminVPN">
        <item name="android:statusBarColor">#0D0D14</item>
    </style>

    <style name="CardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">#252536</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="BlueButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">#2979FF</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="GridButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">14dp</item>
        <item name="strokeColor">#3D3D5C</item>
        <item name="android:textColor">#E0E0E0</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">12sp</item>
        <item name="backgroundTint">#252536</item>
    </style>
</resources>

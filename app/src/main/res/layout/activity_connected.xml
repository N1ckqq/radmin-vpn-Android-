<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient_dark"
    android:fitsSystemWindows="true">

    <!-- Top Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <FrameLayout
            android:id="@+id/btnBack"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_nav_item"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="#E0E0E0" />

        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/connected_title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginStart="12dp" />

        <!-- Connection Timer -->
        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00:00"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#00E676"
            android:fontFamily="monospace" />

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp">

            <!-- Connected Orb -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_gravity="center_horizontal">

                <View
                    android:id="@+id/viewConnectedPulseOuter"
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_connection_orb_connected"
                    android:alpha="0.2" />

                <View
                    android:id="@+id/viewConnectedPulseInner"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_connection_orb_connected"
                    android:alpha="0.5" />

                <View
                    android:id="@+id/viewConnectedOrb"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_connection_orb_connected" />

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_lock_lock"
                    app:tint="#FFFFFF" />

            </FrameLayout>

            <!-- Server Info Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#1A1A2E"
                app:strokeColor="#1B5E20"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_card_dark">

                            <TextView
                                android:id="@+id/tvServerFlag"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="🇯🇵"
                                android:textSize="20sp" />

                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:id="@+id/tvServerName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Server Name"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#E0E0E0" />

                            <TextView
                                android:id="@+id/tvServerCountry"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Japan"
                                android:textSize="12sp"
                                android:textColor="#6E6E7E" />

                        </LinearLayout>

                        <View
                            android:id="@+id/viewStatusIndicator"
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@drawable/bg_connection_orb_connected" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#2D2D44"
                        android:layout_marginVertical="12dp" />

                    <!-- Stats Grid -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/ip_label"
                                android:textSize="10sp"
                                android:textColor="#6E6E7E" />

                            <TextView
                                android:id="@+id/tvServerIp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0.0.0.0"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="#00E676"
                                android:fontFamily="monospace" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/speed_label"
                                android:textSize="10sp"
                                android:textColor="#6E6E7E" />

                            <TextView
                                android:id="@+id/tvServerSpeed"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 Mbps"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="#E0E0E0" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/ping_label"
                                android:textSize="10sp"
                                android:textColor="#6E6E7E" />

                            <TextView
                                android:id="@+id/tvServerPing"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 ms"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="#E0E0E0" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/uptime_label"
                                android:textSize="10sp"
                                android:textColor="#6E6E7E" />

                            <TextView
                                android:id="@+id/tvServerUptime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0h"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="#E0E0E0" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Live Traffic Stats -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#1A1A2E"
                app:strokeColor="#2D2D44"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/live_traffic"
                        android:textSize="12sp"
                        android:textColor="#2979FF"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#2D2D44"
                        android:layout_marginVertical="10dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Upload Stats -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@android:drawable/arrow_up_float"
                                app:tint="#2979FF" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/upload_label"
                                android:textSize="10sp"
                                android:textColor="#6E6E7E"
                                android:layout_marginTop="4dp" />

                            <TextView
                                android:id="@+id/tvUploadSpeed"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 KB/s"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#2979FF" />

                            <TextView
                                android:id="@+id/tvUploadTotal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total: 0 MB"
                                android:textSize="10sp"
                                android:textColor="#6E6E7E"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="#2D2D44" />

                        <!-- Download Stats -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@android:drawable/arrow_down_float"
                                app:tint="#00E676" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/download_label"
                                android:textSize="10sp"
                                android:textColor="#6E6E7E"
                                android:layout_marginTop="4dp" />

                            <TextView
                                android:id="@+id/tvDownloadSpeed"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 KB/s"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#00E676" />

                            <TextView
                                android:id="@+id/tvDownloadTotal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total: 0 MB"
                                android:textSize="10sp"
                                android:textColor="#6E6E7E"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Generate Share Key Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGenerateShareKey"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:text="@string/generate_share_key"
                android:textSize="15sp"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_button_success"
                app:backgroundTint="@null"
                app:cornerRadius="14dp"
                app:icon="@android:drawable/ic_input_add"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="#FFFFFF"
                app:rippleColor="#4DFFFFFF" />

            <!-- Key Display Area -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardKeyDisplay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#0D1B0D"
                app:strokeColor="#1B5E20"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/your_share_key"
                        android:textSize="11sp"
                        android:textColor="#00E676"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:id="@+id/tvShareKey"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text=""
                        android:textSize="11sp"
                        android:textColor="#A5D6A7"
                        android:fontFamily="monospace"
                        android:background="@drawable/bg_key_display"
                        android:padding="12dp"
                        android:maxLines="4"
                        android:ellipsize="end" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="10dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCopyKey"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            android:text="@string/copy_key"
                            android:textSize="12sp"
                            android:textAllCaps="false"
                            android:textColor="#00E676"
                            app:backgroundTint="#1A2E1A"
                            app:cornerRadius="10dp"
                            app:icon="@android:drawable/ic_menu_save"
                            app:iconGravity="textStart"
                            app:iconPadding="4dp"
                            app:iconSize="16dp"
                            app:iconTint="#00E676"
                            app:rippleColor="#3300E676" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnShareKey"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp"
                            android:text="@string/share_key"
                            android:textSize="12sp"
                            android:textAllCaps="false"
                            android:textColor="#2979FF"
                            app:backgroundTint="#1A1A2E"
                            app:cornerRadius="10dp"
                            app:icon="@android:drawable/ic_menu_share"
                            app:iconGravity="textStart"
                            app:iconPadding="4dp"
                            app:iconSize="16dp"
                            app:iconTint="#2979FF"
                            app:rippleColor="#332979FF" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Join With Key Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#1A1A2E"
                app:strokeColor="#2D2D44"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/join_with_key"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#E0E0E0" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="10dp"
                        android:gravity="center_vertical">

                        <EditText
                            android:id="@+id/etJoinKey"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_input_field"
                            android:hint="@string/paste_key_hint"
                            android:textColorHint="#4E4E5E"
                            android:textColor="#E0E0E0"
                            android:textSize="12sp"
                            android:fontFamily="monospace"
                            android:paddingHorizontal="12dp"
                            android:inputType="text"
                            android:maxLines="1"
                            android:layout_marginEnd="8dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnJoinConnect"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:text="@string/connect"
                            android:textSize="13sp"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            app:backgroundTint="#2979FF"
                            app:cornerRadius="10dp"
                            app:rippleColor="#4DFFFFFF" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Disconnect Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDisconnect"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"
                android:text="@string/disconnect"
                android:textSize="15sp"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_button_danger"
                app:backgroundTint="@null"
                app:cornerRadius="14dp"
                app:icon="@android:drawable/ic_menu_close_clear_cancel"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="#FFFFFF"
                app:rippleColor="#4DFF5252" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>

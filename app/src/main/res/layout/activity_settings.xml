<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient_dark"
    android:fitsSystemWindows="true">

    <!-- Top Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <FrameLayout
            android:id="@+id/btnBack"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_nav_item"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="#E0E0E0" />

        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/settings"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginStart="12dp" />

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <!-- INTERFACE Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#1A1A2E"
                app:strokeColor="#2D2D44"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_interface"
                        android:textSize="12sp"
                        android:textColor="#2979FF"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#2D2D44"
                        android:layout_marginVertical="12dp" />

                    <!-- Theme Picker -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_theme"
                                android:textSize="14sp"
                                android:textColor="#E0E0E0" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_theme_desc"
                                android:textSize="11sp"
                                android:textColor="#6E6E7E" />

                        </LinearLayout>

                        <Spinner
                            android:id="@+id/spinnerTheme"
                            android:layout_width="120dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_input_field"
                            android:paddingHorizontal="12dp"
                            android:popupBackground="#1A1A2E" />

                    </LinearLayout>

                    <!-- Accent Color -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_accent_color"
                                android:textSize="14sp"
                                android:textColor="#E0E0E0" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_accent_desc"
                                android:textSize="11sp"
                                android:textColor="#6E6E7E" />

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/layoutAccentColors"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <View
                                android:id="@+id/colorBlue"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:background="@drawable/bg_connection_orb"
                                android:layout_marginEnd="6dp" />

                            <View
                                android:id="@+id/colorGreen"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:background="@drawable/bg_connection_orb_connected"
                                android:layout_marginEnd="6dp" />

                            <View
                                android:id="@+id/colorPurple"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:background="@drawable/bg_button_primary"
                                android:layout_marginEnd="6dp" />

                            <View
                                android:id="@+id/colorRed"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:background="@drawable/bg_button_danger" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Font Size -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/settings_font_size"
                                android:textSize="14sp"
                                android:textColor="#E0E0E0" />

                            <TextView
                                android:id="@+id/tvFontSizeValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="14sp"
                                android:textSize="13sp"
                                android:textColor="#2979FF" />

                        </LinearLayout>

                        <SeekBar
                            android:id="@+id/seekFontSize"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:min="12"
                            android:max="20"
                            android:progress="14"
                            android:progressTint="#2979FF"
                            android:thumbTint="#2979FF"
                            android:layout_marginTop="8dp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- NETWORK Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#1A1A2E"
                app:strokeColor="#2D2D44"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_network"
                        android:textSize="12sp"
                        android:textColor="#00E676"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#2D2D44"
                        android:layout_marginVertical="12dp" />

                    <!-- DNS Servers -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_dns"
                            android:textSize="14sp"
                            android:textColor="#E0E0E0" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_dns_desc"
                            android:textSize="11sp"
                            android:textColor="#6E6E7E"
                            android:layout_marginBottom="8dp" />

                        <EditText
                            android:id="@+id/etDnsPrimary"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_input_field"
                            android:hint="@string/settings_dns_primary_hint"
                            android:textColorHint="#4E4E5E"
                            android:textColor="#E0E0E0"
                            android:textSize="13sp"
                            android:fontFamily="monospace"
                            android:paddingHorizontal="14dp"
                            android:inputType="text"
                            android:maxLines="1"
                            android:layout_marginBottom="8dp" />

                        <EditText
                            android:id="@+id/etDnsSecondary"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_input_field"
                            android:hint="@string/settings_dns_secondary_hint"
                            android:textColorHint="#4E4E5E"
                            android:textColor="#E0E0E0"
                            android:textSize="13sp"
                            android:fontFamily="monospace"
                            android:paddingHorizontal="14dp"
                            android:inputType="text"
                            android:maxLines="1" />

                    </LinearLayout>

                    <!-- MTU Size -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/settings_mtu"
                                android:textSize="14sp"
                                android:textColor="#E0E0E0" />

                            <TextView
                                android:id="@+id/tvMtuValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1400"
                                android:textSize="13sp"
                                android:textColor="#00E676"
                                android:fontFamily="monospace" />

                        </LinearLayout>

                        <SeekBar
                            android:id="@+id/seekMtu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:min="1200"
                            android:max="1500"
                            android:progress="1400"
                            android:progressTint="#00E676"
                            android:thumbTint="#00E676"
                            android:layout_marginTop="8dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="4dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="1200"
                                android:textSize="10sp"
                                android:textColor="#4E4E5E" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1500"
                                android:textSize="10sp"
                                android:textColor="#4E4E5E" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Protocol Selector -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_protocol"
                                android:textSize="14sp"
                                android:textColor="#E0E0E0" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_protocol_desc"
                                android:textSize="11sp"
                                android:textColor="#6E6E7E" />

                        </LinearLayout>

                        <Spinner
                            android:id="@+id/spinnerProtocol"
                            android:layout_width="120dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_input_field"
                            android:paddingHorizontal="12dp"
                            android:popupBackground="#1A1A2E" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- SERVERS Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#1A1A2E"
                app:strokeColor="#2D2D44"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_servers_section"
                        android:textSize="12sp"
                        android:textColor="#FF9800"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#2D2D44"
                        android:layout_marginVertical="12dp" />

                    <!-- API Mirror URLs -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_mirrors"
                        android:textSize="14sp"
                        android:textColor="#E0E0E0"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_mirrors_desc"
                        android:textSize="11sp"
                        android:textColor="#6E6E7E"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:id="@+id/layoutMirrorList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <EditText
                            android:id="@+id/etNewMirror"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_input_field"
                            android:hint="@string/settings_mirror_hint"
                            android:textColorHint="#4E4E5E"
                            android:textColor="#E0E0E0"
                            android:textSize="12sp"
                            android:paddingHorizontal="12dp"
                            android:inputType="textUri"
                            android:maxLines="1"
                            android:layout_marginEnd="8dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAddMirror"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="@string/add"
                            android:textSize="12sp"
                            android:textAllCaps="false"
                            app:backgroundTint="#FF9800"
                            app:cornerRadius="10dp"
                            app:rippleColor="#4DFFFFFF" />

                    </LinearLayout>

                    <!-- Auto Connect Toggle -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_auto_connect"
                                android:textSize="14sp"
                                android:textColor="#E0E0E0" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_auto_connect_desc"
                                android:textSize="11sp"
                                android:textColor="#6E6E7E" />

                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchAutoConnect"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:thumbTint="#2979FF"
                            app:trackTint="#2D2D44" />

                    </LinearLayout>

                    <!-- Preferred Country -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/settings_preferred_country"
                            android:textSize="14sp"
                            android:textColor="#E0E0E0" />

                        <Spinner
                            android:id="@+id/spinnerCountry"
                            android:layout_width="120dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_input_field"
                            android:paddingHorizontal="12dp"
                            android:popupBackground="#1A1A2E" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ABOUT Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#1A1A2E"
                app:strokeColor="#2D2D44"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_about"
                        android:textSize="12sp"
                        android:textColor="#9E9EAE"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#2D2D44"
                        android:layout_marginVertical="12dp" />

                    <!-- Version -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/settings_version"
                            android:textSize="14sp"
                            android:textColor="#E0E0E0" />

                        <TextView
                            android:id="@+id/tvVersion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1.0.0"
                            android:textSize="13sp"
                            android:textColor="#6E6E7E" />

                    </LinearLayout>

                    <!-- GitHub Link -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGithub"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:text="@string/settings_github"
                        android:textSize="13sp"
                        android:textAllCaps="false"
                        android:textColor="#E0E0E0"
                        app:backgroundTint="#252536"
                        app:cornerRadius="10dp"
                        app:icon="@android:drawable/ic_menu_view"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp"
                        app:iconTint="#6E6E7E"
                        app:rippleColor="#332979FF"
                        android:layout_marginBottom="8dp" />

                    <!-- Clear Cache -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClearCache"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:text="@string/settings_clear_cache"
                        android:textSize="13sp"
                        android:textAllCaps="false"
                        android:textColor="#FF5252"
                        app:backgroundTint="#2E1A1A"
                        app:cornerRadius="10dp"
                        app:icon="@android:drawable/ic_menu_delete"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp"
                        app:iconTint="#FF5252"
                        app:rippleColor="#33FF5252" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Save Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveSettings"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"
                android:text="@string/settings_saved"
                android:textSize="15sp"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_button_primary"
                app:backgroundTint="@null"
                app:cornerRadius="14dp"
                app:icon="@android:drawable/ic_menu_save"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="#FFFFFF"
                app:rippleColor="#4DFFFFFF" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121218">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="#0D0D14">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <ImageButton
            android:id="@+id/btnSettingsTop"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_manage"
            android:contentDescription="@string/settings"
            app:tint="#9E9EAE" />

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="56dp"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Status Indicator: Big Circle + Pulse -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <FrameLayout
                        android:layout_width="100dp"
                        android:layout_height="100dp">

                        <View
                            android:id="@+id/viewPulseOuter"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:background="@drawable/circle_pulse"
                            android:layout_gravity="center"
                            android:alpha="0.3" />

                        <View
                            android:id="@+id/viewStatusDot"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/circle_status"
                            android:layout_gravity="center" />

                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/status_disconnected"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#E0E0E0"
                        android:layout_marginTop="12dp" />

                    <TextView
                        android:id="@+id/tvStatusMessage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/status_hint_disconnected"
                        android:textSize="13sp"
                        android:textColor="#9E9EAE"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

            </FrameLayout>

            <!-- Network Info Card (visible when connected) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardNetworkInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#252536"
                app:strokeColor="#3D3D5C"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/network_id_label"
                            android:textSize="11sp"
                            android:textColor="#2979FF"
                            android:letterSpacing="0.1" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCopyId"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:text="@string/copy"
                            android:textSize="11sp"
                            android:textColor="#2979FF"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:minWidth="0dp"
                            android:padding="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvNetworkId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.3" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#3D3D5C"
                        android:layout_marginVertical="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/your_ip"
                                android:textSize="11sp"
                                android:textColor="#9E9EAE" />

                            <TextView
                                android:id="@+id/tvVirtualIp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="10.0.0.1"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#00E676"
                                android:fontFamily="monospace" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/peers"
                                android:textSize="11sp"
                                android:textColor="#9E9EAE" />

                            <TextView
                                android:id="@+id/tvPeerCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#E0E0E0" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Peer List -->
                    <LinearLayout
                        android:id="@+id/layoutPeers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="8dp"
                        android:visibility="gone" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Action Buttons (visible when disconnected) -->
            <LinearLayout
                android:id="@+id/layoutActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCreateNetwork"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/create_network"
                    android:textSize="16sp"
                    android:textAllCaps="false"
                    android:backgroundTint="#2979FF"
                    app:cornerRadius="14dp"
                    app:icon="@android:drawable/ic_input_add"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    app:iconTint="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/or_join_existing"
                    android:textSize="12sp"
                    android:textColor="#6E6E7E"
                    android:layout_gravity="center"
                    android:layout_marginVertical="10dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:boxCornerRadiusTopStart="14dp"
                    app:boxCornerRadiusTopEnd="14dp"
                    app:boxCornerRadiusBottomStart="14dp"
                    app:boxCornerRadiusBottomEnd="14dp"
                    android:hint="@string/enter_network_id"
                    app:boxBackgroundMode="outline"
                    app:boxStrokeColor="#3D3D5C"
                    app:hintTextColor="#6E6E7E"
                    android:textColorHint="#6E6E7E">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNetworkId"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapCharacters"
                        android:maxLength="6"
                        android:textSize="20sp"
                        android:textColor="#E0E0E0"
                        android:gravity="center"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.3" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnJoinNetwork"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/join_network"
                    android:textSize="16sp"
                    android:textAllCaps="false"
                    app:cornerRadius="14dp"
                    app:strokeColor="#2979FF"
                    app:strokeWidth="1dp"
                    android:textColor="#2979FF"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:icon="@android:drawable/ic_menu_share"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    app:iconTint="#2979FF" />

            </LinearLayout>

            <!-- Disconnect Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDisconnect"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/disconnect"
                android:textSize="16sp"
                android:textAllCaps="false"
                app:cornerRadius="14dp"
                android:backgroundTint="#FF5252"
                android:visibility="gone"
                android:layout_marginBottom="16dp"
                app:icon="@android:drawable/ic_menu_close_clear_cancel"
                app:iconGravity="textStart"
                app:iconPadding="8dp" />

            <!-- Connection Methods Grid (2x3) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/method_firebase"
                android:textSize="12sp"
                android:textColor="#6E6E7E"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <GridLayout
                android:id="@+id/gridMethods"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:rowCount="2"
                android:layout_marginBottom="16dp"
                android:useDefaultMargins="true">

                <!-- Row 1 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFirebase"
                    android:layout_width="0dp"
                    android:layout_height="88dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#252536"
                    app:strokeColor="#3D3D5C"
                    app:strokeWidth="1dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@android:drawable/ic_menu_upload"
                            app:tint="#2979FF" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/method_firebase"
                            android:textSize="11sp"
                            android:textColor="#E0E0E0"
                            android:layout_marginTop="6dp"
                            android:gravity="center" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardDirectIp"
                    android:layout_width="0dp"
                    android:layout_height="88dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#252536"
                    app:strokeColor="#3D3D5C"
                    app:strokeWidth="1dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@android:drawable/ic_menu_mapmode"
                            app:tint="#2979FF" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/method_direct_ip"
                            android:textSize="11sp"
                            android:textColor="#E0E0E0"
                            android:layout_marginTop="6dp"
                            android:gravity="center" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardShareKey"
                    android:layout_width="0dp"
                    android:layout_height="88dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#252536"
                    app:strokeColor="#3D3D5C"
                    app:strokeWidth="1dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@android:drawable/ic_menu_share"
                            app:tint="#2979FF" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/method_share_key"
                            android:textSize="11sp"
                            android:textColor="#E0E0E0"
                            android:layout_marginTop="6dp"
                            android:gravity="center" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Row 2 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAutoFind"
                    android:layout_width="0dp"
                    android:layout_height="88dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#252536"
                    app:strokeColor="#3D3D5C"
                    app:strokeWidth="1dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@android:drawable/ic_menu_search"
                            app:tint="#2979FF" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/method_auto_find"
                            android:textSize="11sp"
                            android:textColor="#E0E0E0"
                            android:layout_marginTop="6dp"
                            android:gravity="center" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardManual"
                    android:layout_width="0dp"
                    android:layout_height="88dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#252536"
                    app:strokeColor="#3D3D5C"
                    app:strokeWidth="1dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@android:drawable/ic_lock_idle_lock"
                            app:tint="#2979FF" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/method_manual"
                            android:textSize="11sp"
                            android:textColor="#E0E0E0"
                            android:layout_marginTop="6dp"
                            android:gravity="center" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSettings"
                    android:layout_width="0dp"
                    android:layout_height="88dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#252536"
                    app:strokeColor="#3D3D5C"
                    app:strokeWidth="1dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@android:drawable/ic_menu_manage"
                            app:tint="#9E9EAE" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/method_settings"
                            android:textSize="11sp"
                            android:textColor="#9E9EAE"
                            android:layout_marginTop="6dp"
                            android:gravity="center" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

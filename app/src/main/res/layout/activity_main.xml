<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_dark"
    android:fitsSystemWindows="true">

    <!-- Top App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:paddingHorizontal="16dp"
            app:contentInsetStart="0dp"
            app:contentInsetEnd="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- App Title Section -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/app_name"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />

                    <TextView
                        android:id="@+id/tvTopIpAddress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/status_disconnected"
                        android:textSize="11sp"
                        android:textColor="#9E9EAE" />

                </LinearLayout>

                <!-- Connection Timer -->
                <TextView
                    android:id="@+id/tvConnectionTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00:00"
                    android:textSize="14sp"
                    android:textColor="#00E676"
                    android:fontFamily="monospace"
                    android:visibility="gone"
                    android:layout_marginEnd="16dp" />

                <!-- Settings Button -->
                <FrameLayout
                    android:id="@+id/btnTopSettings"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_nav_item"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_menu_manage"
                        app:tint="#9E9EAE" />

                </FrameLayout>

            </LinearLayout>

        </androidx.appcompat.widget.Toolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content Area -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp">

            <!-- Connection Orb Section -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:layout_gravity="center_horizontal">

                <!-- Outer Pulse Ring -->
                <View
                    android:id="@+id/viewOrbPulseOuter"
                    android:layout_width="220dp"
                    android:layout_height="220dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_connection_orb"
                    android:alpha="0.2" />

                <!-- Middle Pulse Ring -->
                <View
                    android:id="@+id/viewOrbPulseMiddle"
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_connection_orb"
                    android:alpha="0.4" />

                <!-- Main Connection Orb -->
                <View
                    android:id="@+id/viewConnectionOrb"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_connection_orb"
                    android:clickable="true"
                    android:focusable="true" />

                <!-- Power Icon Inside Orb -->
                <ImageView
                    android:id="@+id/ivOrbIcon"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_lock_power_off"
                    app:tint="#FFFFFF" />

            </FrameLayout>

            <!-- Status Text -->
            <TextView
                android:id="@+id/tvConnectionStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/status_disconnected"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#E0E0E0" />

            <TextView
                android:id="@+id/tvConnectionSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/status_hint_disconnected"
                android:textSize="13sp"
                android:textColor="#6E6E7E"
                android:layout_marginTop="4dp" />

            <!-- Quick Connect Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnQuickConnect"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="24dp"
                android:text="@string/quick_connect"
                android:textSize="16sp"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:background="@drawable/bg_button_primary"
                android:textColor="#FFFFFF"
                app:backgroundTint="@null"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_media_play"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconTint="#FFFFFF"
                app:rippleColor="#4DFFFFFF" />

            <!-- Recent Server Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRecentServer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#1A1A2E"
                app:strokeColor="#2D2D44"
                app:strokeWidth="1dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="@drawable/bg_nav_item">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <!-- Server Flag Placeholder -->
                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_card_dark">

                        <TextView
                            android:id="@+id/tvRecentServerFlag"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="🇯🇵"
                            android:textSize="22sp" />

                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:id="@+id/tvRecentServerName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Last connected"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#E0E0E0" />

                        <TextView
                            android:id="@+id/tvRecentServerInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Japan • 15ms • 89 Mbps"
                            android:textSize="12sp"
                            android:textColor="#6E6E7E" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_media_play"
                        app:tint="#2979FF" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Action Buttons Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp">

                <!-- Generate Key Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGenerateKey"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="@string/generate_key"
                    android:textSize="13sp"
                    android:textAllCaps="false"
                    android:textColor="#00E676"
                    app:backgroundTint="#1A2E1A"
                    app:cornerRadius="14dp"
                    app:strokeColor="#00E676"
                    app:strokeWidth="1dp"
                    app:icon="@android:drawable/ic_input_add"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp"
                    app:iconTint="#00E676"
                    app:rippleColor="#3300E676" />

                <!-- Join With Key Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnJoinWithKey"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="@string/join_with_key"
                    android:textSize="13sp"
                    android:textAllCaps="false"
                    android:textColor="#2979FF"
                    app:backgroundTint="#1A1A2E"
                    app:cornerRadius="14dp"
                    app:strokeColor="#2979FF"
                    app:strokeWidth="1dp"
                    app:icon="@android:drawable/ic_menu_share"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp"
                    app:iconTint="#2979FF"
                    app:rippleColor="#332979FF" />

            </LinearLayout>

            <!-- Network Info Card (when connected) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardNetworkInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#1A1A2E"
                app:strokeColor="#2D2D44"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/connection_info"
                        android:textSize="12sp"
                        android:textColor="#2979FF"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#2D2D44"
                        android:layout_marginVertical="10dp" />

                    <!-- IP Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/your_ip"
                            android:textSize="13sp"
                            android:textColor="#6E6E7E" />

                        <TextView
                            android:id="@+id/tvConnectedIp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="10.0.0.1"
                            android:textSize="13sp"
                            android:textColor="#00E676"
                            android:fontFamily="monospace" />

                    </LinearLayout>

                    <!-- Server Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/server_label"
                            android:textSize="13sp"
                            android:textColor="#6E6E7E" />

                        <TextView
                            android:id="@+id/tvConnectedServer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="13sp"
                            android:textColor="#E0E0E0" />

                    </LinearLayout>

                    <!-- Speed Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/speed_label"
                            android:textSize="13sp"
                            android:textColor="#6E6E7E" />

                        <TextView
                            android:id="@+id/tvConnectedSpeed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="— Mbps"
                            android:textSize="13sp"
                            android:textColor="#E0E0E0" />

                    </LinearLayout>

                    <!-- Ping Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/ping_label"
                            android:textSize="13sp"
                            android:textColor="#6E6E7E" />

                        <TextView
                            android:id="@+id/tvConnectedPing"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="— ms"
                            android:textSize="13sp"
                            android:textColor="#E0E0E0" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Traffic Stats Card (when connected) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTrafficStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#1A1A2E"
                app:strokeColor="#2D2D44"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <!-- Upload -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@android:drawable/arrow_up_float"
                            app:tint="#2979FF" />

                        <TextView
                            android:id="@+id/tvUploadSpeed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 KB/s"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#2979FF"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:id="@+id/tvUploadTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 MB"
                            android:textSize="11sp"
                            android:textColor="#6E6E7E" />

                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="#2D2D44" />

                    <!-- Download -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@android:drawable/arrow_down_float"
                            app:tint="#00E676" />

                        <TextView
                            android:id="@+id/tvDownloadSpeed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 KB/s"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#00E676"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:id="@+id/tvDownloadTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 MB"
                            android:textSize="11sp"
                            android:textColor="#6E6E7E" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Disconnect Button (when connected) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDisconnect"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:text="@string/disconnect"
                android:textSize="15sp"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:visibility="gone"
                android:background="@drawable/bg_button_danger"
                app:backgroundTint="@null"
                app:cornerRadius="14dp"
                app:icon="@android:drawable/ic_menu_close_clear_cancel"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="#FFFFFF"
                app:rippleColor="#4DFF5252" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation Bar -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#1A1A2E">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp">

            <!-- Home Tab -->
            <FrameLayout
                android:id="@+id/navHome"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_nav_item"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/ivNavHome"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        app:tint="#2979FF" />

                    <TextView
                        android:id="@+id/tvNavHome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/nav_home"
                        android:textSize="10sp"
                        android:textColor="#2979FF"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

            </FrameLayout>

            <!-- Servers Tab -->
            <FrameLayout
                android:id="@+id/navServers"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_nav_item"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/ivNavServers"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_mapmode"
                        app:tint="#6E6E7E" />

                    <TextView
                        android:id="@+id/tvNavServers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/nav_servers"
                        android:textSize="10sp"
                        android:textColor="#6E6E7E"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

            </FrameLayout>

            <!-- Chat Tab -->
            <FrameLayout
                android:id="@+id/navChat"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_nav_item"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/ivNavChat"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_send"
                        app:tint="#6E6E7E" />

                    <TextView
                        android:id="@+id/tvNavChat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/nav_chat"
                        android:textSize="10sp"
                        android:textColor="#6E6E7E"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

            </FrameLayout>

            <!-- Settings Tab -->
            <FrameLayout
                android:id="@+id/navSettings"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_nav_item"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/ivNavSettings"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_preferences"
                        app:tint="#6E6E7E" />

                    <TextView
                        android:id="@+id/tvNavSettings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/nav_settings"
                        android:textSize="10sp"
                        android:textColor="#6E6E7E"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

            </FrameLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Заголовок -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="P2P VPN"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Виртуальная локальная сеть"
            android:textSize="14sp"
            android:textColor="?android:textColorSecondary"
            android:layout_marginBottom="32dp" />

        <!-- Статус -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_disconnected"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:drawablePadding="8dp" />

                <TextView
                    android:id="@+id/tvVirtualIp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvNetworkId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvStatusMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="?android:textColorSecondary"
                    android:layout_marginTop="4dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Кнопка создать сеть -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCreateNetwork"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/create_network"
            android:textSize="16sp"
            app:cornerRadius="12dp"
            android:layout_marginBottom="12dp" />

        <!-- Или -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="или"
            android:textColor="?android:textColorSecondary"
            android:layout_marginBottom="12dp" />

        <!-- Поле ввода ID сети -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            android:hint="@string/enter_network_id">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNetworkId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapCharacters"
                android:maxLength="6"
                android:textSize="18sp"
                android:gravity="center"
                android:letterSpacing="0.2" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Кнопка присоединиться -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnJoinNetwork"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/join_network"
            android:textSize="16sp"
            app:cornerRadius="12dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginBottom="24dp" />

        <!-- Кнопка отключиться (скрыта по умолчанию) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDisconnect"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/disconnect"
            android:textSize="16sp"
            app:cornerRadius="12dp"
            android:backgroundTint="#D32F2F"
            android:visibility="gone"
            android:layout_marginBottom="24dp" />

        <!-- Список пиров -->
        <TextView
            android:id="@+id/tvPeersTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/peers"
            android:textSize="14sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvPeersList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
